{
	"version": 2,
	"redirects": [
		{
			"source": "/",
			"destination": "/react-spa/",
			"permanent": true
		}
	],
	"rewrites": [
		{
			"source": "/react-spa(/?)",
			"destination": "/react-spa/"
		},
		{
			"source": "/react-spa/:file*.:ext",
			"destination": "/:file*.:ext"
		},
		{
			"source": "/react-spa/:path(.*)",
			"destination": "/index.html"
		}
	]
}
