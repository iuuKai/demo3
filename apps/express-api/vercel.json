{
	"version": 2,
	"builds": [
		{
			"src": "public/**/*",
			"use": "@vercel/static"
		},
		{
			"src": "src/app.js",
			"use": "@vercel/node"
		}
	],
	"rewrites": [
		{
			"source": "/(js|css|images)/(.*)",
			"destination": "/public/$1/$2"
		},
		{
			"source": "/:path(.*)",
			"destination": "/src/app.js"
		}
	]
}
