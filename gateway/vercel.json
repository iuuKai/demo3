{
	"version": 2,
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"rewrites": [
		{
			"source": "/astro-ssg(.*)",
			"destination": "https://gateway-astro.vercel.app/$1"
		},
		{
			"source": "/hexo-ssg(.*)",
			"destination": "https://gateway-hexo.vercel.app/$1"
		},
		{
			"source": "/next-ssg(.*)",
			"destination": "https://gateway-next-ssg.vercel.app/$1"
		},
		{
			"source": "/nuxt4-ssg(.*)",
			"destination": "https://gateway-nuxt4-ssg.vercel.app/$1"
		},
		{
			"source": "/react-spa(.*)",
			"destination": "https://gateway-react.vercel.app/$1"
		},
		{
			"source": "/vanilla-spa(.*)",
			"destination": "https://gateway-vanilla.vercel.app/$1"
		},
		{
			"source": "/vitepress-ssg(.*)",
			"destination": "https://gateway-vitepress.vercel.app/$1"
		},
		{
			"source": "/vue3-spa(.*)",
			"destination": "https://gateway-vue3.vercel.app/$1"
		},
		{
			"source": "/vuepress-ssg(.*)",
			"destination": "https://gateway-vuepress.vercel.app/$1"
		},
		{
			"source": "/webpack-ejs-mpa(.*)",
			"destination": "https://gateway-ejs.vercel.app/$1"
		},
		{
			"source": "/next-ssr(.*)",
			"destination": "https://gateway-next-ssr.vercel.app/$1"
		},
		{
			"source": "/nuxt4-ssr(.*)",
			"destination": "https://gateway-nuxt4-ssr.vercel.app/$1"
		},
		{
			"source": "/:path(.*)",
			"destination": "https://gateway-express.vercel.app/:path*"
		}
	]
}
