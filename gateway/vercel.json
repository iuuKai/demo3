{
	"version": 2,
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"rewrites": [
		{
			"source": "/astro-ssg(/?)",
			"destination": "https://gateway-astro.vercel.app"
		},
		{
			"source": "/astro-ssg/:path(.*)",
			"destination": "https://gateway-astro.vercel.app/:path*"
		},
		{
			"source": "/hexo-ssg(/?)",
			"destination": "https://gateway-hexo.vercel.app"
		},
		{
			"source": "/hexo-ssg/:path(.*)",
			"destination": "https://gateway-hexo.vercel.app/:path*"
		},
		{
			"source": "/next-ssg(/?)",
			"destination": "https://gateway-next-ssg.vercel.app/next-ssg"
		},
		{
			"source": "/next-ssg/:path(.*)",
			"destination": "https://gateway-next-ssg.vercel.app/next-ssg/:path*"
		},
		{
			"source": "/nuxt4-ssg(/?)",
			"destination": "https://gateway-nuxt4-ssg.vercel.app"
		},
		{
			"source": "/nuxt4-ssg/:path(.*)",
			"destination": "https://gateway-nuxt4-ssg.vercel.app/:path*"
		},
		{
			"source": "/",
			"destination": "https://gateway-express.vercel.app"
		},
		{
			"source": "/:path(.*)",
			"destination": "https://gateway-express.vercel.app/:path*"
		}
	]
}
